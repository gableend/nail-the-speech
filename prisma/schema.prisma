// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id // Clerk user ID
  email             String?
  isProUser         Boolean   @default(false)
  proExpiresAt      DateTime? // Pro access expires after this date (90 days from payment)
  stripeCustomerId  String?
  stripeSessionId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("users")
}

model PendingPayment {
  id               String   @id @default(cuid())
  email            String
  stripeCustomerId String?
  stripeSessionId  String
  claimed          Boolean  @default(false)
  claimedByUserId  String?
  createdAt        DateTime @default(now())

  @@index([email, claimed])
  @@map("pending_payments")
}

model Speech {
  id            String   @id @default(cuid())
  title         String   // Auto-generated title
  customTitle   String?  // User-defined custom title
  content       String
  role          String
  tone          String
  length        String
  wordCount     Int?
  estimatedTime Int?     // in minutes
  isAIGenerated Boolean  @default(true)
  formData      String   // JSON string of form data
  regenCount    Int      @default(0) // Track full regeneration count
  refineCount   Int      @default(0) // Track refinement count
  userId        String?  // Clerk user ID (set after auth)
  anonUserId    String?  // Client-generated anonymous user ID (set before auth)
  isCompleted   Boolean  @default(true) // false for draft speeches
  isFinal       Boolean  @default(false) // Mark as "Final" version
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  versions      SpeechVersion[]

  @@map("speeches")
}

model EmailLead {
  id              String    @id @default(cuid())
  email           String
  name            String?
  role            String?   // Speech role they selected
  confirmed       Boolean   @default(false)  // Clicked confirm in email 1
  confirmedAt     DateTime?
  hasPaid         Boolean   @default(false)  // Converted to paying customer
  unsubscribed    Boolean   @default(false)
  discountCode    String?   // Stripe coupon code sent in email 2
  email1SentAt    DateTime? // Confirmation email sent
  email2SentAt    DateTime? // Discount email sent
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([email])
  @@index([hasPaid, email1SentAt])
  @@map("email_leads")
}

model UsageLog {
  id               String   @id @default(cuid())
  speechId         String?
  userId           String?
  anonUserId       String?
  action           String   // "generate" | "refine" | "start_over"
  model            String   // "gpt-4o" | "gpt-4o-mini"
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCost    Float?   // in USD cents
  instruction      String?
  ipHash           String?
  suspicionScore   Int?
  suspicionFlags   String?  // JSON array of triggered flags
  userAgent        String?
  blocked          Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([ipHash, createdAt])
  @@map("usage_logs")
}

model SpeechVersion {
  id            String   @id @default(cuid())
  speechId      String
  content       String
  versionNumber Int
  createdAt     DateTime @default(now())

  speech        Speech   @relation(fields: [speechId], references: [id], onDelete: Cascade)

  @@index([speechId, versionNumber])
  @@map("speech_versions")
}

model RateLimit {
  id            String   @id // e.g. "ip:<hash>" or "user:<id>"
  requestCount  Int      @default(0)
  windowStart   DateTime @default(now())
  windowMinutes Int      @default(60)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("rate_limits")
}

model AnonToken {
  id        String   @id @default(cuid())
  ipHash    String
  budget    Int      @default(1)  // Number of generations allowed
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
  @@map("anon_tokens")
}
